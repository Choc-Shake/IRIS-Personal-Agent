# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (for whitelist)
TELEGRAM_USER_ID=

# Ollama Configuration (For Local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Groq API Key (For Level 3 - Voice)
GROQ_API_KEY=

# Pinecone API Key (For Level 2 - Memory)
PINECONE_API_KEY=

# Timezone for the get_current_time tool (e.g., America/Edmonton)
TIMEZONE=America/Edmonton

# --- B.L.A.S.T. Routing Architecture ---
LLM_ROUTING_MODE=HYBRID # Valid options: HYBRID, LOCAL_ONLY, CLOUD_ONLY
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
LOCAL_MODEL=qwen3:14b
OPENROUTER_API_KEY=
